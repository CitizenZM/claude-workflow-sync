{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/wecom/callback(.*)", "dest": "/api/wecom/callback.js" },
    { "src": "/webhook-send", "dest": "/api/webhook-send.js" },
    { "src": "/health", "dest": "/api/health.js" },
    { "src": "/test-send", "dest": "/api/test-send.js" }
  ]
}
