<style>
  .page-hero {
    position: relative;
    width: 100%;
    height: 35vh;
    min-height: 240px;
    max-height: 400px;
    overflow: hidden;
    background: #0a0a0a;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.5) 100%);
  }

  .page-hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 70%;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 40%, transparent 100%);
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .page-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    animation: pageKenBurns 20s ease-in-out infinite alternate;
  }

  .page-hero__gradient-bg {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0a0a0a 0%, #15101e 30%, #0a1520 60%, #0a0a0a 100%);
    animation: pageKenBurns 20s ease-in-out infinite alternate;
  }

  @keyframes pageKenBurns {
    0% { transform: scale(1); }
    100% { transform: scale(1.05) translate(-0.2%, -0.2%); }
  }

  .page-hero__particles {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
  }

  .page-hero__particle {
    position: absolute;
    width: 2px;
    height: 2px;
    background: rgba(255, 215, 180, 0.2);
    border-radius: 50%;
    animation: pageParticle linear infinite;
    box-shadow: 0 0 4px rgba(255, 180, 120, 0.15);
  }

  .page-hero__particle:nth-child(1) { left: 15%; animation-duration: 24s; animation-delay: 0s; }
  .page-hero__particle:nth-child(2) { left: 45%; animation-duration: 20s; animation-delay: -5s; width: 3px; height: 3px; }
  .page-hero__particle:nth-child(3) { left: 75%; animation-duration: 22s; animation-delay: -3s; }
  .page-hero__particle:nth-child(4) { left: 92%; animation-duration: 26s; animation-delay: -8s; }

  @keyframes pageParticle {
    0% { transform: translateY(40vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.6; }
    100% { transform: translateY(-5vh) rotate(360deg); opacity: 0; }
  }

  .page-hero__content {
    position: relative;
    z-index: 5;
    padding: 2.5rem 3rem;
    max-width: 700px;
  }

  .page-hero__badge {
    display: inline-block;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 200, 160, 0.7);
    border: 1px solid rgba(255, 200, 160, 0.2);
    padding: 0.35em 1.2em;
    margin-bottom: 1rem;
    backdrop-filter: blur(4px);
    background: rgba(0,0,0,0.2);
    opacity: 0;
    transform: translateY(15px);
    animation: pageReveal 0.8s ease-out 0.2s forwards;
  }

  .page-hero__title {
    font-family: var(--font-heading-family, 'Georgia', serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.1;
    color: #fff;
    margin: 0;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 30px rgba(0,0,0,0.5);
    opacity: 0;
    transform: translateY(20px);
    animation: pageReveal 1s ease-out 0.4s forwards;
  }

  @keyframes pageReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .page-hero__line {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    z-index: 6;
    background: linear-gradient(90deg, transparent, rgba(255, 200, 160, 0.2) 20%, rgba(255, 200, 160, 0.2) 80%, transparent);
  }

  @media screen and (max-width: 749px) {
    .page-hero { height: 28vh; min-height: 200px; }
    .page-hero__content { padding: 1.5rem; }
    .page-hero__title { font-size: clamp(1.5rem, 6vw, 2.2rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-hero__gradient-bg, .page-hero__img { animation: none !important; }
    .page-hero__particle { animation: none !important; display: none; }
    .page-hero__badge, .page-hero__title {
      animation: none !important; opacity: 1 !important; transform: none !important;
    }
  }
</style>

<div class="page-hero">
  <div class="page-hero__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'page-hero__img', loading: 'eager', sizes: '100vw', widths: '800,1200,1600,2000' }}
    {%- else -%}
      <div class="page-hero__gradient-bg"></div>
    {%- endif -%}
  </div>

  <div class="page-hero__particles" aria-hidden="true">
    <div class="page-hero__particle"></div>
    <div class="page-hero__particle"></div>
    <div class="page-hero__particle"></div>
    <div class="page-hero__particle"></div>
  </div>

  <div class="page-hero__content">
    {%- if section.settings.show_badge -%}
      <div class="page-hero__badge">{{ section.settings.badge_text }}</div>
    {%- endif -%}
    <h1 class="page-hero__title">{{ page.title }}</h1>
  </div>

  <div class="page-hero__line"></div>
</div>

{% schema %}
{
  "name": "Page Hero Cinematic",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "default": true,
      "label": "Show badge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "default": "Dark Fantasy",
      "label": "Badge text"
    }
  ]
}
{% endschema %}
